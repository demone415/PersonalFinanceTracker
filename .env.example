# Copy to .env and adjust for your environment: cp .env.example .env
# docker compose reads these automatically.

# ── PostgreSQL ──
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=finance

# ── RabbitMQ ──
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ── Backend ──
ASPNETCORE_ENVIRONMENT=Development

# ── Frontend (baked into the Vite build) ──
VITE_API_URL=http://localhost:5000

# ── Added in later tasks ──
# SUPABASE_JWT_SECRET=        # T1.2.1 (GoTrue / .NET JWT validation)
# SUPABASE_ANON_KEY=          # T1.2.6 (frontend supabase-js client)
# MINIO_ROOT_USER=            # T1.1.9 (object storage)
# MINIO_ROOT_PASSWORD=        # T1.1.9
