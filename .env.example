# Copy to .env and adjust for your environment: cp .env.example .env
# docker compose reads these automatically.

# ── PostgreSQL ──
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=finance

# ── RabbitMQ ──
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ── MinIO (S3-compatible object storage) ──
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── Supabase GoTrue (auth) ──
# Shared HS256 secret: GoTrue signs JWTs with it, the .NET API validates with it.
# Must be >= 32 chars. Generate a strong value for any non-local environment.
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
GOTRUE_EXTERNAL_URL=http://localhost:9999
GOTRUE_SITE_URL=http://localhost:3000

# ── Backend ──
ASPNETCORE_ENVIRONMENT=Development

# ── Frontend (baked into the Vite build) ──
VITE_API_URL=http://localhost:5000

# ── Added in later tasks ──
# SUPABASE_ANON_KEY=          # T1.2.6 (frontend supabase-js client)
